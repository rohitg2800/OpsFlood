# Frontend runtime configuration (Vite)

# Backend API base URL (FastAPI)
# Local dev example:
# Leave this unset for the single-container Render deployment so the app uses same-origin requests.
VITE_API_BASE_URL=http://localhost:8000

# Weather API key now lives on the backend only.
# Set OPENWEATHER_API_KEY in `backend/.env.local` or server env.
